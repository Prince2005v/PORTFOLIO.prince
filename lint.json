font-bold text-white/60 border border-white/5 h-fit\">\n                    {exp.duration}\n                  </span>\n                </div>\n                <p className=\"text-white/50 leading-relaxed\">\n                  {exp.description}\n                </p>\n              </div>\n            </motion.div>\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Applications/Developer/Project/portfolio/src/components/sections/Hero.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Applications/Developer/Project/portfolio/src/components/sections/Projects.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'index' is defined but never used.","line":33,"column":49,"nodeType":"Identifier","messageId":"unusedVar","endLine":33,"endColumn":54}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport { motion } from \"framer-motion\";\nimport { portfolioData } from \"@/data/portfolio\";\nimport { ExternalLink, Github, ArrowUpRight } from \"lucide-react\";\nimport Link from \"next/link\";\n\nexport function Projects() {\n  return (\n    <section id=\"projects\" className=\"py-24 px-6\">\n      <div className=\"max-w-7xl mx-auto\">\n        <div className=\"mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6\">\n          <div>\n            <h2 className=\"text-3xl md:text-5xl font-bold tracking-tight mb-4 text-white\">\n              Featured <span className=\"gradient-text\">Work</span>\n            </h2>\n            <p className=\"text-white/60 max-w-lg\">\n              Showcase of some of my most impactful projects, ranging from AI full-stack applications to secure decentralized protocols.\n            </p>\n          </div>\n          <Link href={portfolioData.contact.github} target=\"_blank\" className=\"text-white/60 hover:text-white flex items-center gap-2 group transition-colors\">\n            View all projects on GitHub <ArrowUpRight className=\"group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" />\n          </Link>\n        </div>\n\n        <motion.div \n          initial={{ opacity: 0 }}\n          whileInView={{ opacity: 1 }}\n          transition={{ staggerChildren: 0.1 }}\n          viewport={{ once: true }}\n          className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\"\n        >\n          {portfolioData.projects.map((project, index) => (\n            <motion.div\n              key={project.id}\n              variants={{\n                hidden: { opacity: 0, y: 30 },\n                visible: { opacity: 1, y: 0 }\n              }}\n              initial=\"hidden\"\n              whileInView=\"visible\"\n              viewport={{ once: true }}\n              className=\"glass-card p-1 rounded-[2rem] overflow-hidden group\"\n            >\n              <div className=\"p-8 h-full flex flex-col\">\n                <div className=\"flex justify-between items-start mb-6\">\n                  <div className=\"px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-blue-400 bg-blue-500/10 rounded-full border border-blue-500/20\">\n                    {project.type}\n                  </div>\n                  <div className=\"flex gap-4\">\n                    <Link href={project.github} target=\"_blank\" className=\"text-white/40 hover:text-white transition-colors\">\n                      <Github size={20} />\n                    </Link>\n                    <Link href={project.link} target=\"_blank\" className=\"text-white/40 hover:text-white transition-colors\">\n                      <ExternalLink size={20} />\n                    </Link>\n                  </div>\n                </div>\n\n                <h3 className=\"text-2xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors\">\n                  {project.title}\n                </h3>\n                <p className=\"text-white/50 text-sm leading-relaxed mb-6 flex-grow\">\n                  {project.description}\n                </p>\n\n                <div className=\"flex flex-wrap gap-2 mt-auto\">\n                  {project.tech.map((t) => (\n                    <span key={t} className=\"text-[10px] uppercase font-bold text-white/30\">\n                      {t}\n                    </span>\n                  ))}\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </motion.div>\n      </div>\n    </section>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Applications/Developer/Project/portfolio/src/components/sections/Skills.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Applications/Developer/Project/portfolio/src/components/ui/DevTerminal.tsx","messages":[{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":22,"column":16,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[640,698],"text":"\n          Type &apos;help' to see available commands.\n        "},"desc":"Replace with `&apos;`."},{"messageId":"replaceWithAlt","data":{"alt":"&lsquo;"},"fix":{"range":[640,698],"text":"\n          Type &lsquo;help' to see available commands.\n        "},"desc":"Replace with `&lsquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#39;"},"fix":{"range":[640,698],"text":"\n          Type &#39;help' to see available commands.\n        "},"desc":"Replace with `&#39;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rsquo;"},"fix":{"range":[640,698],"text":"\n          Type &rs